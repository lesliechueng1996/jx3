{
  "$schema": "https://biomejs.dev/schemas/2.4.5/schema.json",
  "extends": ["../../biome.json"],
  "files": {
    "includes": [
      "**/src/**/*",
      "**/tests/**/*",
      "**/.vscode/**/*",
      "**/index.html",
      "**/vite.config.ts",
      "**/vitest.config.ts",
      "!**/src/routeTree.gen.ts",
      "!**/src/styles.css",
      "!**/src/components/ui/*"
    ]
  },
  "overrides": [
    {
      "includes": ["**/src/components/ui/**"],
      "linter": {
        "rules": {
          "a11y": {
            "useSemanticElements": "off"
          },
          "suspicious": {
            "noArrayIndexKey": "off"
          }
        }
      }
    }
  ]
}
