{
  "name": "@jx3/api",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun --packages external",
    "lint": "biome lint .",
    "check": "biome check .",
    "typecheck": "tsc --noEmit",
    "fix": "biome check --write .",
    "test": "bun test --isolate",
    "test:cov": "bun test --isolate --coverage --coverage-reporter=text --coverage-reporter=lcov"
  },
  "dependencies": {
    "@elysiajs/cors": "latest",
    "@elysiajs/swagger": "latest",
    "@jx3/auth": "workspace:*",
    "@jx3/db": "workspace:*",
    "@jx3/jx3api": "workspace:*",
    "@jx3/logger": "workspace:*",
    "@supabase/supabase-js": "^2.106.2",
    "drizzle-orm": "^0.44.0",
    "elysia": "latest",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.5",
    "bun-types": "latest"
  }
}
